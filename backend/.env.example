# ============================================================
# IHO - Índice de Saúde Operacional — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores

# ── Banco de Dados ──────────────────────────────────────────
# PostgreSQL (padrão para Replit e produção)
DATABASE_URL="postgresql://usuario:senha@localhost:5432/iho_db"

# MySQL (uso local alternativo — lembre de mudar provider no prisma/schema.prisma)
# DATABASE_URL="mysql://usuario:senha@localhost:3306/iho_db"

# ── Servidor ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5000

# ── Autenticação JWT ─────────────────────────────────────────
JWT_SECRET=troque-por-uma-chave-segura-de-32-caracteres
JWT_REFRESH_SECRET=troque-por-outra-chave-segura-de-32-caracteres
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ── InfinitePay ──────────────────────────────────────────────
INFINITEPAY_HANDLE=sua_infinite_tag
INFINITEPAY_API_URL=https://api.infinitepay.io
INFINITEPAY_WEBHOOK_SECRET=seu_webhook_secret

# ── E-mail (SMTP) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app
SMTP_FROM=seu_email@gmail.com
SMTP_FROM_NAME="IHO - Índice de Saúde Operacional"

# ── Segurança / CORS ─────────────────────────────────────────
CORS_ORIGIN=http://localhost:5000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
SESSION_SECRET=troque-por-uma-session-secret-segura

# ── Redis (necessário para filas Bull) ──────────────────────
# Se não usar Redis, as filas não funcionarão; o restante do sistema funciona
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Logs ─────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=combined

# ── Upload de Arquivos ───────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ── Sistema ──────────────────────────────────────────────────
SYSTEM_NAME="IHO - Índice de Saúde Operacional"
SYSTEM_VERSION=1.0.0
DIAS_TOLERANCIA_ATRASO=10
DIAS_IMPLANTACAO=10
DIAS_PRIMEIRA_MENSALIDADE=40

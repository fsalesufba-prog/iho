# Database
DATABASE_URL="mysql://usuario:senha@host:3306/database"

# App
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Auth
JWT_SECRET=seu_jwt_secret_aqui
JWT_REFRESH_SECRET=seu_refresh_secret_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# InfinitePay
INFINITEPAY_HANDLE=sua_infinite_tag
INFINITEPAY_API_URL=https://api.infinitepay.io
INFINITEPAY_WEBHOOK_SECRET=seu_webhook_secret

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_app
SMTP_FROM=seu_email@gmail.com
SMTP_FROM_NAME="IHO - Índice de Saúde Operacional"

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
SESSION_SECRET=sua_session_secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Logs
LOG_LEVEL=debug
LOG_FORMAT=combined

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# System
SYSTEM_NAME="IHO - Índice de Saúde Operacional"
SYSTEM_VERSION=1.0.0
DIAS_TOLERANCIA_ATRASO=10
DIAS_IMPLANTACAO=10
DIAS_PRIMEIRA_MENSALIDADE=40
modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "5000"
NODE_ENV = "production"
APP_URL = "https://aeeef924-7752-4e12-8c4a-670cfe837867-00-nac7d0zotxlr.janeway.replit.dev"
FRONTEND_URL = "https://aeeef924-7752-4e12-8c4a-670cfe837867-00-nac7d0zotxlr.janeway.replit.dev"

NEXT_PUBLIC_API_URL = "https://aeeef924-7752-4e12-8c4a-670cfe837867-00-nac7d0zotxlr.janeway.replit.dev/api"
NEXT_PUBLIC_ENVIRONMENT = "production"
NEXT_PUBLIC_ENABLE_DARK_MODE = "true"
NEXT_PUBLIC_ENABLE_ANALYTICS = "false"
NEXT_PUBLIC_INFINITEPAY_HANDLE = "fernanda-dos-349"
JWT_EXPIRES_IN = "15m"
JWT_REFRESH_EXPIRES_IN = "7d"
BCRYPT_ROUNDS = "10"
SMTP_HOST = "smtp.gmail.com"
